# ─────────────────────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ─────────────────────────────────────────────────────────────
# Xcode — user-specific state (never commit these)
# ─────────────────────────────────────────────────────────────
xcuserdata/
*.xcuserstate
*.xcuserstate*
*.xccheckout
*.xcscmblueprint
*.moved-aside

# Xcode project file user settings (pre-Xcode 9 era, still safe to ignore)
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# ─────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────
build/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# ─────────────────────────────────────────────────────────────
# Swift Package Manager
# .build/ is local package build output — never commit.
# Package.resolved SHOULD be committed when you add SPM deps,
# so it is intentionally NOT ignored.
# ─────────────────────────────────────────────────────────────
.build/
.swiftpm/build/

# ─────────────────────────────────────────────────────────────
# Dependency managers (only relevant if adopted later)
# ─────────────────────────────────────────────────────────────
Pods/
Carthage/Build/

# ─────────────────────────────────────────────────────────────
# fastlane (only relevant if adopted later)
# https://docs.fastlane.tools/best-practices/source-control/
# ─────────────────────────────────────────────────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# ─────────────────────────────────────────────────────────────
# Project-specific
# ─────────────────────────────────────────────────────────────
# Local xcodebuild cache used by scripts/build-and-launch.sh
.derived-data/

# Screenshot captured by scripts/build-and-launch.sh on each launch
screenshots/latest.png
